name: Web CI

on:
  push:
    branches:
      - main
      - develop
      - "release/*"
  pull_request:

permissions:
  contents: read

jobs:
  web:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Set up Node.js
        uses: actions/setup-node@v4
        with:
          node-version: "{{ node_version }}"

      - name: Verify Next.js web scaffold
        shell: bash
        run: |
          if [ ! -f apps/web/package.json ]; then
            echo "apps/web/package.json is not generated by this scaffold. Skipping web verification."
            exit 0
          fi
          cd apps/web
          corepack enable || true
          if [ -f pnpm-lock.yaml ]; then
            pnpm install --frozen-lockfile || pnpm install
            pnpm build || echo "No build script found. Skipping build."
          elif [ -f yarn.lock ]; then
            yarn install --frozen-lockfile || yarn install
            yarn build || echo "No build script found. Skipping build."
          else
            npm install
            npm run build || echo "No build script found. Skipping build."
          fi
