## Adding a Feature End-to-End

Follow these steps every time you add a new resource or action. This is the workflow described in [ways-of-working.md](ways-of-working.md).

### Step 1: Define the Entity (Symfony)

Create a Doctrine entity in `apps/api/src/Entity/`:

```php
// apps/api/src/Entity/Product.php
{% if api_style == "api-platform" %}
use ApiPlatform\Metadata\ApiResource;
use ApiPlatform\Metadata\Get;
use ApiPlatform\Metadata\GetCollection;
use ApiPlatform\Metadata\Post;
use ApiPlatform\Metadata\Put;
use ApiPlatform\Metadata\Delete;

#[ApiResource(
    operations: [
        new Get(),
        new GetCollection(),
        new Post(security: "is_granted('ROLE_USER')"),
        new Put(security: "is_granted('ROLE_USER') and object.owner == user"),
        new Delete(security: "is_granted('ROLE_ADMIN')"),
    ],
    normalizationContext: ['groups' => ['product:read']],
    denormalizationContext: ['groups' => ['product:write']],
)]
{% endif %}
#[ORM\Entity(repositoryClass: ProductRepository::class)]
class Product
{
    #[ORM\Id]
    #[ORM\Column(type: 'uuid', unique: true)]
    #[ORM\GeneratedValue(strategy: 'CUSTOM')]
    #[ORM\CustomIdGenerator(class: UuidV7Generator::class)]
    {% if api_style == "api-platform" %}#[Groups(['product:read'])]{% endif %}
    private Uuid $id;

    #[ORM\Column(length: 255)]
    #[Assert\NotBlank]
    #[Assert\Length(max: 255)]
    {% if api_style == "api-platform" %}#[Groups(['product:read', 'product:write'])]{% endif %}
    private string $name;

    // ... getters/setters
}
```

Generate and run the migration:
```bash
php bin/console doctrine:migrations:diff
php bin/console doctrine:migrations:migrate
```

{% if api_style == "custom-controllers" %}
### Step 2: Create the Controller

```php
// apps/api/src/Controller/ProductController.php
#[Route('/api/products')]
class ProductController extends AbstractController
{
    #[Route('', methods: ['GET'])]
    public function list(ProductRepository $repository, Request $request): JsonResponse
    {
        $page = max(1, (int) $request->query->get('page', 1));
        $perPage = min(100, max(1, (int) $request->query->get('perPage', 20)));

        $paginator = $repository->paginate($page, $perPage);

        return $this->json(
            PaginationResponseBuilder::build($paginator, $page, $perPage),
            Response::HTTP_OK,
        );
    }

    #[Route('/{id}', methods: ['GET'])]
    public function show(Product $product): JsonResponse
    {
        return $this->json($product);
    }

    #[Route('', methods: ['POST'])]
    public function create(Request $request, ProductService $service): JsonResponse
    {
        $dto = $this->deserializeAndValidate($request, CreateProductDto::class);
        $product = $service->create($dto);
        return $this->json($product, Response::HTTP_CREATED);
    }
}
```
{% endif %}

### Step 3: Generate / Update Shared Types

{% if api_style == "api-platform" %}
After changing the entity, regenerate the shared types:

```bash
# Requires the Symfony dev server to be running
pnpm --filter shared-types generate
```

Commit the updated `packages/shared-types/src/index.ts` in the same PR.
{% else %}
Update `packages/shared-types/src/index.ts` by hand:

```typescript
// packages/shared-types/src/index.ts
export interface Product {
  id: string;
  name: string;
  price: number;
  createdAt: string;
  updatedAt: string;
}
```

Ensure the shape exactly matches what the Symfony serializer outputs.
{% endif %}

### Step 4: Build the Frontend Service

```typescript
// apps/web/src/services/products.ts
import { api } from '@/lib/api';
import type { Product, PaginatedResponse } from '@{{ project_name }}/shared-types';

export async function getProducts(page = 1, perPage = 20): Promise<PaginatedResponse<Product>> {
  return api.get<PaginatedResponse<Product>>(`/products?page=${page}&perPage=${perPage}`);
}

export async function getProduct(id: string): Promise<Product> {
  return api.get<Product>(`/products/${id}`);
}

export async function createProduct(data: CreateProductInput): Promise<Product> {
  return api.post<Product>('/products', data);
}

export async function updateProduct(id: string, data: Partial<CreateProductInput>): Promise<Product> {
  return api.patch<Product>(`/products/${id}`, data);
}

export async function deleteProduct(id: string): Promise<void> {
  return api.delete(`/products/${id}`);
}
```

The `api` helper in `lib/api.ts` handles base URL, auth headers, error parsing, and retry on 401.

### Step 5: Build the UI

See the page templates:
- [Dashboard page](page-templates/dashboard.md) - list view with pagination
- [Detail page](page-templates/detail.md) - single entity view
- [Form page](page-templates/form.md) - create/edit form with validation

A minimal list page using Server Components:

```typescript
// apps/web/src/app/(dashboard)/products/page.tsx
import { getProducts } from '@/services/products';
import { ProductTable } from '@/components/features/products/ProductTable';

export default async function ProductsPage() {
  // Fetched on the server - no client-side loading state needed
  const { data: products, meta } = await getProducts();

  return (
    <main>
      <h1>Products</h1>
      <ProductTable products={products} />
    </main>
  );
}
```

