## Client Component: UserForm

The form component handles all input state, client-side validation, submission, error mapping, and navigation.

```typescript
// apps/web/src/components/features/users/UserForm.tsx
'use client';

import { useState, useTransition } from 'react';
import { useRouter } from 'next/navigation';
import { createUser, updateUser } from '@/services/users';
import type { User } from '@{{ project_name }}/shared-types';

interface ApiViolation {
  field: string;
  message: string;
}

interface UserFormProps {
  mode: 'create' | 'edit';
  defaultValues?: Partial<User>;
  userId?: string;
}

export function UserForm({ mode, defaultValues, userId }: UserFormProps) {
  const router = useRouter();
  const [isPending, startTransition] = useTransition();

  const [values, setValues] = useState({
    name: defaultValues?.name ?? '',
    email: defaultValues?.email ?? '',
    role: defaultValues?.role ?? 'ROLE_USER',
  });

  // Field-level errors from the Symfony API (422 violations) or client validation
  const [errors, setErrors] = useState<Record<string, string>>({});
  const [submitError, setSubmitError] = useState<string | null>(null);

  const validate = (): boolean => {
    const next: Record<string, string> = {};
    if (!values.name.trim()) next.name = 'Name is required.';
    if (!values.email.trim()) next.email = 'Email is required.';
    else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(values.email)) {
      next.email = 'Enter a valid email address.';
    }
    setErrors(next);
    return Object.keys(next).length === 0;
  };

  const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault();
    setSubmitError(null);

    // Client-side validation first (UX only - API will also validate)
    if (!validate()) return;

    startTransition(async () => {
      try {
        if (mode === 'create') {
          const created = await createUser(values);
          router.push(`/users/${created.id}`);
        } else {
          await updateUser(userId!, values);
          router.refresh();
        }
      } catch (err: unknown) {
        // Map 422 violations from the API to field errors
        if (isApiError(err) && err.status === 422 && err.violations) {
          const fieldErrors: Record<string, string> = {};
          (err.violations as ApiViolation[]).forEach(({ field, message }) => {
            fieldErrors[field] = message;
          });
          setErrors(fieldErrors);
        } else {
          setSubmitError('An unexpected error occurred. Please try again.');
        }
      }
    });
  };

  return (
    <form onSubmit={handleSubmit} className="space-y-6" noValidate>
      {submitError && (
        <div role="alert" className="text-red-600 text-sm p-3 rounded bg-red-50 border border-red-200">
          {submitError}
        </div>
      )}

      <div className="grid grid-cols-1 gap-4 sm:grid-cols-2">
        <div>
          <label htmlFor="name" className="form-label">
            Full Name <span aria-hidden="true">*</span>
          </label>
          <input
            id="name"
            type="text"
            value={values.name}
            onChange={(e) => setValues((v) => ({ ...v, name: e.target.value }))}
            aria-invalid={!!errors.name}
            aria-describedby={errors.name ? 'name-error' : undefined}
            className={`form-input ${errors.name ? 'border-red-500' : ''}`}
          />
          {errors.name && (
            <p id="name-error" role="alert" className="text-red-600 text-xs mt-1">
              {errors.name}
            </p>
          )}
        </div>

        <div>
          <label htmlFor="email" className="form-label">
            Email <span aria-hidden="true">*</span>
          </label>
          <input
            id="email"
            type="email"
            value={values.email}
            onChange={(e) => setValues((v) => ({ ...v, email: e.target.value }))}
            aria-invalid={!!errors.email}
            aria-describedby={errors.email ? 'email-error' : undefined}
            className={`form-input ${errors.email ? 'border-red-500' : ''}`}
          />
          {errors.email && (
            <p id="email-error" role="alert" className="text-red-600 text-xs mt-1">
              {errors.email}
            </p>
          )}
        </div>
      </div>

      <div className="flex gap-3 pt-4 justify-end">
        <a href={mode === 'edit' && userId ? `/users/${userId}` : '/users'}
           className="btn btn-secondary">
          Cancel
        </a>
        <button type="submit" disabled={isPending} className="btn btn-primary">
          {isPending ? (mode === 'create' ? 'Creating...' : 'Saving...') : (mode === 'create' ? 'Create User' : 'Save Changes')}
        </button>
      </div>
    </form>
  );
}

function isApiError(err: unknown): err is { status: number; violations?: unknown[] } {
  return typeof err === 'object' && err !== null && 'status' in err;
}
```

---

## Validation Mapping: Symfony to Frontend

The Symfony API returns 422 violations in this format (see [api-contract.md](../api-contract.md)):

```json
{
  "status": 422,
  "violations": [
    { "field": "name", "message": "This value should not be blank." },
    { "field": "email", "message": "This value is not a valid email address." }
  ]
}
```

The frontend maps the `field` key directly to form field names. **Field names in the API response must match the HTML input `name`/`id` attributes.** This is a contract requirement documented in `docs/api-contract.md`.

If the API returns a violation for a field that does not exist in the frontend form (e.g. `passwordHash`), it falls into the `submitError` bucket as a generic error.

---

## Accessibility Requirements

Every form field must have:
- A `<label>` with `htmlFor` matching the input `id`
- `aria-invalid="true"` when the field has an error
- `aria-describedby` pointing to the error message element when an error exists
- The error message element must have `role="alert"`
- Submit button must be disabled during submission (prevent double-submit)
- The form must work without JavaScript (progressive enhancement where possible)

---

## API Calls Made by This Page

| Endpoint | Method | Mode | Purpose |
|----------|--------|------|---------|
| `GET /api/users/{id}` | GET | Edit | Pre-populate form |
| `POST /api/users` | POST | Create | Submit new entity |
| `PATCH /api/users/{id}` | PATCH | Edit | Submit changes |

