## Server Component (Edit Mode)

```typescript
// apps/web/src/app/(dashboard)/users/[id]/edit/page.tsx

import { notFound } from 'next/navigation';
import { getUser } from '@/services/users';
import { UserForm } from '@/components/features/users/UserForm';
import { Breadcrumb } from '@/components/ui/Breadcrumb';

interface EditUserPageProps {
  params: { id: string };
}

export default async function EditUserPage({ params }: EditUserPageProps) {
  const user = await getUser(params.id).catch(() => null);
  if (!user) notFound();

  return (
    <main className="space-y-6 p-6 max-w-2xl">
      <Breadcrumb
        items={[
          { label: 'Users', href: '/users' },
          { label: user.name, href: `/users/${user.id}` },
          { label: 'Edit' },
        ]}
      />
      <div>
        <h1 className="text-2xl font-semibold">Edit {user.name}</h1>
        <p className="text-gray-500 mt-1">Update the account details below.</p>
      </div>
      {/* UserForm is a Client Component - it handles all form state */}
      <UserForm mode="edit" defaultValues={user} userId={user.id} />
    </main>
  );
}
```

```typescript
