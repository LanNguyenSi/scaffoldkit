## Client Component: DeleteDialog

Destructive actions require explicit confirmation. The dialog handles its own open/close state, then calls a Server Action (or the API directly) on confirm.

```typescript
// apps/web/src/components/features/users/DeleteDialog.tsx
'use client';

import { useState, useTransition } from 'react';
import { useRouter } from 'next/navigation';
import { deleteUser } from '@/services/users';

interface DeleteDialogProps {
  userId: string;
  userName: string;
}

export function DeleteDialog({ userId, userName }: DeleteDialogProps) {
  const [open, setOpen] = useState(false);
  const [isPending, startTransition] = useTransition();
  const router = useRouter();

  const handleDelete = () => {
    startTransition(async () => {
      await deleteUser(userId);
      router.push('/users');
      router.refresh();
    });
  };

  return (
    <>
      <button
        onClick={() => setOpen(true)}
        className="btn btn-danger-outline text-sm"
      >
        Delete
      </button>

      {open && (
        <div role="dialog" aria-modal>
          <p>Are you sure you want to delete <strong>{userName}</strong>?</p>
          <p className="text-sm text-gray-500">This action cannot be undone.</p>
          <div className="flex gap-2 justify-end mt-4">
            <button onClick={() => setOpen(false)} disabled={isPending}>
              Cancel
            </button>
            <button onClick={handleDelete} disabled={isPending} className="btn btn-danger">
              {isPending ? 'Deleting...' : 'Delete'}
            </button>
          </div>
        </div>
      )}
    </>
  );
}
```

