## Component Breakdown

| Component | Type | Responsibility |
|-----------|------|----------------|
| `UserDetailPage` | Server Component | Fetch entity, pass to children |
| `EntityHeader` | Server Component | Name, avatar, key attributes, status badge |
| `Breadcrumb` | Server Component | Static navigation trail |
| `DetailsGrid` | Server Component | Label/value pairs |
| `RelatedList` | Server Component | Paginated related entities (first page only) |
| `ActionMenu` | **Client Component** | Edit / More dropdown (needs `useState`) |
| `DeleteDialog` | **Client Component** | Confirmation modal before delete |
| `StatusToggle` | **Client Component** | Toggle active/inactive with optimistic UI |
| `InlineEditField` | **Client Component** | Click-to-edit a single field |

---

## Server Component Implementation

```typescript
// apps/web/src/app/(dashboard)/users/[id]/page.tsx

import { notFound } from 'next/navigation';
import { getUser } from '@/services/users';
import { getUserOrders } from '@/services/orders';
import { EntityHeader } from '@/components/features/users/EntityHeader';
import { DetailsGrid } from '@/components/features/users/DetailsGrid';
import { RelatedOrdersList } from '@/components/features/users/RelatedOrdersList';
import { ActionMenu } from '@/components/features/users/ActionMenu';
import { DeleteDialog } from '@/components/features/users/DeleteDialog';
import { Breadcrumb } from '@/components/ui/Breadcrumb';

interface UserDetailPageProps {
  params: { id: string };
}

export default async function UserDetailPage({ params }: UserDetailPageProps) {
  // Parallel fetch: the user and their recent orders
  const [user, ordersResult] = await Promise.all([
    getUser(params.id).catch(() => null),
    getUserOrders(params.id, { perPage: 5 }).catch(() => null),
  ]);

  // Let Next.js render the 404 page - do not render an error state here
  if (!user) notFound();

  return (
    <main className="space-y-6 p-6">
      <Breadcrumb
        items={[
          { label: 'Dashboard', href: '/dashboard' },
          { label: 'Users', href: '/users' },
          { label: user.name },
        ]}
      />

      <div className="flex items-start justify-between">
        <EntityHeader user={user} />
        <div className="flex gap-2">
          {/* Client Components for interactions */}
          <ActionMenu userId={user.id} />
          <DeleteDialog userId={user.id} userName={user.name} />
        </div>
      </div>

      <div className="grid grid-cols-1 gap-6 lg:grid-cols-3">
        <div className="lg:col-span-2">
          <DetailsGrid user={user} />
        </div>
        <div>
          <RelatedOrdersList orders={ordersResult?.data ?? []} userId={user.id} />
        </div>
      </div>
    </main>
  );
}

export async function generateMetadata({ params }: UserDetailPageProps) {
  const user = await getUser(params.id).catch(() => null);
  return {
    title: user ? `${user.name} - {{ display_name }}` : 'User Not Found',
  };
}
```

