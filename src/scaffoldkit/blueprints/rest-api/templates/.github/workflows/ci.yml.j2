name: CI

on:
  push:
    branches:
      - main
      - develop
      - "release/*"
  pull_request:

permissions:
  contents: read

jobs:
  verify:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v4
{% if framework == "fastapi" or framework == "django-rest" %}
      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Verify Python API scaffold
        shell: bash
        run: |
          if [ -f requirements.txt ]; then
            pip install -r requirements.txt
          elif [ -f pyproject.toml ]; then
            pip install .
          else
            echo "No Python dependency manifest found. Skipping framework-specific verification."
            exit 0
          fi
          if command -v pytest >/dev/null 2>&1; then
            pytest || true
          else
            echo "pytest is not installed yet. Skipping test run."
          fi
{% elif framework == "express" %}
      - name: Set up Node.js
        uses: actions/setup-node@v4
        with:
          node-version: "22"

      - name: Verify Node API scaffold
        shell: bash
        run: |
          if [ ! -f package.json ]; then
            echo "package.json is not generated by this scaffold. Add the Node bootstrap to enable CI verification."
            exit 0
          fi
          corepack enable || true
          if [ -f pnpm-lock.yaml ]; then
            pnpm install --frozen-lockfile || pnpm install
          elif [ -f package-lock.json ]; then
            npm ci
          elif [ -f yarn.lock ]; then
            yarn install --frozen-lockfile || yarn install
          else
            npm install
          fi
          if npm run | grep -qE '(^| )lint( |$)'; then npm run lint; else echo "No lint script found. Skipping lint."; fi
          if npm run | grep -qE '(^| )test( |$)'; then npm test -- --runInBand || npm test; else echo "No test script found. Skipping tests."; fi
          if npm run | grep -qE '(^| )build( |$)'; then npm run build; else echo "No build script found. Skipping build."; fi
{% else %}
      - name: Set up Java
        uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: "21"

      - name: Verify Spring API scaffold
        shell: bash
        run: |
          if [ -f pom.xml ]; then
            if [ -f mvnw ]; then chmod +x mvnw && ./mvnw verify; else mvn verify; fi
          elif [ -f build.gradle ] || [ -f build.gradle.kts ]; then
            if [ -f gradlew ]; then chmod +x gradlew && ./gradlew build; else gradle build; fi
          else
            echo "Spring build files are not generated by this scaffold. Add the framework bootstrap to enable CI verification."
          fi
{% endif %}

{% if use_docker %}
  docker-build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Build Docker image
        run: docker build -t {{ project_name }}:ci .
{% endif %}
