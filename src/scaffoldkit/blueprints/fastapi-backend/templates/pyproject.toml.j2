[build-system]
requires = ["hatchling>=1.26"]
build-backend = "hatchling.build"

{% if package_manager == "poetry" -%}
[tool.poetry]
name = "{{ project_name }}"
version = "0.1.0"
description = "{{ description }}"
authors = ["ScaffoldKit <noreply@example.com>"]
readme = "README.md"
package-mode = false

[tool.poetry.dependencies]
python = "^{{ python_version }}"
fastapi = "^0.115.12"
uvicorn = { extras = ["standard"], version = "^0.34.0" }
sqlalchemy = "^2.0.40"
alembic = "^1.15.2"
{% if db_provider == "postgresql" -%}
psycopg = { extras = ["binary"], version = "^3.2.6" }
{% elif db_provider == "mysql" -%}
pymysql = "^1.1.1"
{% endif -%}
{% if auth_strategy == "jwt" -%}
pyjwt = "^2.10.1"
{% elif auth_strategy == "oauth2" -%}
authlib = "^1.5.2"
{% elif auth_strategy == "api-key" -%}
passlib = "^1.7.4"
{% endif -%}
{% if use_redis -%}
redis = "^5.2.1"
{% endif -%}

[tool.poetry.group.dev.dependencies]
httpx = "^0.28.1"
pytest = "^8.3.5"
pytest-asyncio = "^0.26.0"
ruff = "^0.11.2"
{% else -%}
[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "{{ description }}"
readme = "README.md"
requires-python = ">={{ python_version }}"
dependencies = [
  "fastapi>=0.115.12,<0.116.0",
  "uvicorn[standard]>=0.34.0,<0.35.0",
  "sqlalchemy>=2.0.40,<3.0.0",
  "alembic>=1.15.2,<2.0.0",
{% if db_provider == "postgresql" -%}
  "psycopg[binary]>=3.2.6,<4.0.0",
{% elif db_provider == "mysql" -%}
  "pymysql>=1.1.1,<2.0.0",
{% endif -%}
{% if auth_strategy == "jwt" -%}
  "pyjwt>=2.10.1,<3.0.0",
{% elif auth_strategy == "oauth2" -%}
  "authlib>=1.5.2,<2.0.0",
{% elif auth_strategy == "api-key" -%}
  "passlib>=1.7.4,<2.0.0",
{% endif -%}
{% if use_redis -%}
  "redis>=5.2.1,<6.0.0",
{% endif -%}
]

[dependency-groups]
dev = [
  "httpx>=0.28.1,<0.29.0",
  "pytest>=8.3.5,<9.0.0",
  "pytest-asyncio>=0.26.0,<0.27.0",
  "ruff>=0.11.2,<0.12.0",
]

[tool.uv]
package = false
{% endif %}

[tool.pytest.ini_options]
pythonpath = ["."]
testpaths = ["tests"]

[tool.ruff]
line-length = 100
target-version = "py{{ python_version | replace('.', '') }}"
