services:
  api:
    build:
      context: .
      dockerfile: Dockerfile
    volumes:
      - ./:/app
    ports:
      - "8000:8000"
    environment:
{% if db_provider == "postgresql" %}
      DATABASE_URL: postgresql://app:password@db:5432/{{ project_name }}
{% elif db_provider == "mysql" %}
      DATABASE_URL: mysql://app:password@db:3306/{{ project_name }}
{% elif db_provider == "sqlite" %}
      DATABASE_URL: sqlite:///./var/{{ project_name }}.db
{% endif %}
{% if use_redis %}
      REDIS_URL: redis://redis:6379/0
{% endif %}
    depends_on:
{% if db_provider != "sqlite" %}
      db:
        condition: service_started
{% endif %}
{% if use_redis %}
      redis:
        condition: service_started
{% endif %}

{% if db_provider == "postgresql" %}
  db:
    image: postgres:15
    environment:
      POSTGRES_DB: {{ project_name }}
      POSTGRES_USER: app
      POSTGRES_PASSWORD: password
    ports:
      - "5432:5432"
    volumes:
      - db-data:/var/lib/postgresql/data
{% elif db_provider == "mysql" %}
  db:
    image: mysql:8.0
    environment:
      MYSQL_DATABASE: {{ project_name }}
      MYSQL_USER: app
      MYSQL_PASSWORD: password
      MYSQL_ROOT_PASSWORD: root
    ports:
      - "3306:3306"
    volumes:
      - db-data:/var/lib/mysql
{% endif %}
{% if use_redis %}
  redis:
    image: redis:7-alpine
    ports:
      - "6379:6379"
{% endif %}

volumes:
{% if db_provider != "sqlite" %}
  db-data:
{% endif %}
