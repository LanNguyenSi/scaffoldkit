name: CI

on:
  push:
    branches:
      - main
      - develop
      - "release/*"
  pull_request:

permissions:
  contents: read

jobs:
  verify:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v4
{% if language == "python" %}
      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Verify Python CLI scaffold
        shell: bash
        run: |
          if [ -f pyproject.toml ] || [ -f requirements.txt ]; then
            echo "Python bootstrap detected. Run the project-specific lint/test commands here."
          else
            echo "Python bootstrap files are not generated by this scaffold. Skipping CI verification."
          fi
{% elif language == "go" %}
      - name: Set up Go
        uses: actions/setup-go@v5
        with:
          go-version: "1.22"

      - name: Verify Go CLI scaffold
        shell: bash
        run: |
          if [ -f go.mod ]; then
            go test ./...
          else
            echo "go.mod is not generated by this scaffold. Skipping CI verification."
          fi
{% elif language == "rust" %}
      - name: Set up Rust
        uses: dtolnay/rust-toolchain@stable

      - name: Verify Rust CLI scaffold
        shell: bash
        run: |
          if [ -f Cargo.toml ]; then
            cargo test
          else
            echo "Cargo.toml is not generated by this scaffold. Skipping CI verification."
          fi
{% elif language == "typescript" %}
      - name: Set up Node.js
        uses: actions/setup-node@v4
        with:
          node-version: "22"

      - name: Verify TypeScript CLI scaffold
        shell: bash
        run: |
          if [ ! -f package.json ]; then
            echo "package.json is not generated by this scaffold. Skipping CI verification."
            exit 0
          fi
          corepack enable || true
          if [ -f pnpm-lock.yaml ]; then
            pnpm install --frozen-lockfile || pnpm install
            pnpm test || echo "No test script found. Skipping tests."
            pnpm exec tsc --noEmit || true
            npm pack --ignore-scripts
          elif [ -f yarn.lock ]; then
            yarn install --frozen-lockfile || yarn install
            yarn test || echo "No test script found. Skipping tests."
            yarn tsc --noEmit || true
            npm pack --ignore-scripts
          else
            npm install
            npm test || echo "No test script found. Skipping tests."
            npx tsc --noEmit || true
            npm pack --ignore-scripts
          fi
{% endif %}
