FROM ubuntu:24.04

WORKDIR /workspace

RUN apt-get update \
    && apt-get install -y --no-install-recommends bash ca-certificates curl git python3 python3-pip python3-venv \
    && rm -rf /var/lib/apt/lists/*

COPY . .

CMD ["bash", "-lc", "python3 -m venv /tmp/venv && . /tmp/venv/bin/activate && pip install -e . && cd apps/api && python manage.py runserver 0.0.0.0:8000"]
