services:
{% if stack == "nextjs-fullstack" or stack == "symfony-api-react" %}
  web:
    build:
      context: .
      dockerfile: Dockerfile
    environment:
      APP_ROLE: web
    ports:
{% if stack == "nextjs-fullstack" -%}
      - "3000:3000"
{% else -%}
      - "5173:5173"
{% endif %}
    volumes:
      - ./:/workspace

  api:
    build:
      context: .
      dockerfile: Dockerfile
    environment:
      APP_ROLE: api
      DATABASE_URL: postgresql://app:password@db:5432/{{ project_name }}
    ports:
{% if stack == "nextjs-fullstack" -%}
      - "8080:8080"
{% else -%}
      - "8000:8000"
{% endif %}
    volumes:
      - ./:/workspace
    depends_on:
      db:
        condition: service_started
{% else %}
  app:
    build:
      context: .
      dockerfile: Dockerfile
    environment:
      APP_ROLE: app
      DATABASE_URL: postgresql://app:password@db:5432/{{ project_name }}
    ports:
      - "8000:8000"
    volumes:
      - ./:/workspace
    depends_on:
      db:
        condition: service_started
{% endif %}

  db:
    image: postgres:15
    environment:
      POSTGRES_DB: {{ project_name }}
      POSTGRES_USER: app
      POSTGRES_PASSWORD: password
    ports:
      - "5432:5432"
    volumes:
      - db-data:/var/lib/postgresql/data

volumes:
  db-data:
