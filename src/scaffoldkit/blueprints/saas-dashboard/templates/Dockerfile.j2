FROM ubuntu:24.04

WORKDIR /workspace

RUN apt-get update \
    && apt-get install -y --no-install-recommends bash ca-certificates curl git \
    && rm -rf /var/lib/apt/lists/*

COPY . .

CMD ["bash", "-lc", "echo 'SaaS dashboard scaffold shell: add concrete apps under apps/web and apps/api to run services.' && sleep infinity"]
