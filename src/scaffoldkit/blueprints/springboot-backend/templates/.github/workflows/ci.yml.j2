name: CI

on:
  push:
    branches:
      - main
      - develop
      - "release/*"
  pull_request:

permissions:
  contents: read

jobs:
  verify:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Set up Java {{ java_version }}
        uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: "{{ java_version }}"

      - name: Verify {{ build_tool }} project
        shell: bash
        run: |
{% if build_tool == "maven" %}
          if [ -f pom.xml ]; then
            if [ -f mvnw ]; then chmod +x mvnw && ./mvnw verify; else mvn verify; fi
          else
            echo "pom.xml is not generated by this scaffold. Add the Spring Boot bootstrap to enable CI verification."
          fi
{% else %}
          if [ -f build.gradle ] || [ -f build.gradle.kts ]; then
            if [ -f gradlew ]; then chmod +x gradlew && ./gradlew build; else gradle build; fi
          else
            echo "Gradle build files are not generated by this scaffold. Add the Spring Boot bootstrap to enable CI verification."
          fi
{% endif %}

{% if use_docker %}
  docker-build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Build Docker image
        run: docker build -t {{ project_name }}:ci .
{% endif %}
