services:
  web:
    build:
      context: .
      dockerfile: Dockerfile
    command: >
      sh -c "if [ -f package.json ];
      then corepack enable || true &&
      if [ -f pnpm-lock.yaml ]; then pnpm start --hostname 0.0.0.0;
      elif [ -f package-lock.json ]; then npm run start;
      elif [ -f yarn.lock ]; then yarn start --hostname 0.0.0.0 || yarn start;
      else npm run start; fi;
      else echo 'Next.js scaffold: add package.json and a production start script.' && sleep infinity; fi"
    ports:
      - "3000:3000"
