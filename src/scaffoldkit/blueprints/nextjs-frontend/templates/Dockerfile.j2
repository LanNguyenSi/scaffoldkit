FROM node:22-alpine

ENV NEXT_TELEMETRY_DISABLED=1

WORKDIR /app

COPY . .

RUN corepack enable || true \
    && if [ -f package.json ]; then \
         if [ -f pnpm-lock.yaml ]; then pnpm install --frozen-lockfile || pnpm install; \
         elif [ -f package-lock.json ]; then npm ci; \
         elif [ -f yarn.lock ]; then yarn install --frozen-lockfile || yarn install; \
         else npm install; fi; \
         if [ -f pnpm-lock.yaml ]; then pnpm build || true; \
         elif [ -f package-lock.json ]; then npm run build || true; \
         elif [ -f yarn.lock ]; then yarn build || true; \
         else npm run build || true; fi; \
       else \
         echo "No package.json found. Keeping scaffold image minimal."; \
       fi

EXPOSE 3000

CMD ["sh", "-c", "if [ -f package.json ]; then corepack enable || true; if [ -f pnpm-lock.yaml ]; then pnpm dev --hostname 0.0.0.0; elif [ -f package-lock.json ]; then npm run dev -- --hostname 0.0.0.0 || npm run dev; elif [ -f yarn.lock ]; then yarn dev --hostname 0.0.0.0 || yarn dev; else npm run dev -- --hostname 0.0.0.0 || npm run dev; fi; else echo 'Next.js scaffold: add package.json to run the frontend.'; sleep infinity; fi"]
