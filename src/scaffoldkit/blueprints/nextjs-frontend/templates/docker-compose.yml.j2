services:
  web:
    build:
      context: .
      dockerfile: Dockerfile
    command: >
      sh -c "if [ -f package.json ];
      then corepack enable || true &&
      if [ -f pnpm-lock.yaml ]; then pnpm install --frozen-lockfile || pnpm install; pnpm dev --hostname 0.0.0.0;
      elif [ -f package-lock.json ]; then npm ci || npm install; npm run dev -- --hostname 0.0.0.0 || npm run dev;
      elif [ -f yarn.lock ]; then yarn install --frozen-lockfile || yarn install; yarn dev --hostname 0.0.0.0 || yarn dev;
      else npm install; npm run dev -- --hostname 0.0.0.0 || npm run dev; fi;
      else echo 'Next.js scaffold: add package.json to start the development server.' && sleep infinity; fi"
    ports:
      - "3000:3000"
    volumes:
      - ./:/app
      - node-modules:/app/node_modules

volumes:
  node-modules:
