## Data Fetching Patterns

{% if api_client == "tanstack-query" %}
### TanStack Query (client-side)

Use TanStack Query for data that:
- Needs client-side caching with background refetch
- Depends on user input (search, filters, pagination)
- Must be updated after a mutation (optimistic updates)

```ts
// 1. Define service function and query key
// src/services/products.ts
export const productKeys = {
  all: ["products"] as const,
  list: (filters: ProductFilters) => ["products", "list", filters] as const,
  detail: (id: string) => ["products", "detail", id] as const,
};

export function useProducts(filters: ProductFilters) {
  return useQuery({
    queryKey: productKeys.list(filters),
    queryFn: () => fetchProducts(filters),
    staleTime: 60_000,
  });
}

// 2. Use in a Client Component
"use client";
export function ProductList({ initialFilters }) {
  const [filters, setFilters] = useState(initialFilters);
  const { data, isLoading, isError } = useProducts(filters);

  if (isLoading) return <ProductTableSkeleton />;
  if (isError) return <SectionError />;
  return <ProductTable products={data} />;
}
```

{% elif api_client == "fetch" or api_client == "axios" %}
### Service Layer Pattern

All API calls go through typed service functions in `src/services/`. Components never call `fetch` directly.

```ts
// src/services/products.ts
import { apiFetch } from "@/lib/api"; // shared fetch wrapper

export async function getProducts(filters?: ProductFilters): Promise<Product[]> {
  return apiFetch<Product[]>("/products", {
    params: filters,
  });
}

export async function createProduct(data: CreateProductInput): Promise<Product> {
  return apiFetch<Product>("/products", {
    method: "POST",
    body: JSON.stringify(data),
  });
}
```

{% endif %}

{% if router == "app-router" %}
### Server Components (preferred for static data)

For data that does not change per user interaction, fetch in the Server Component:

```tsx
// No hook, no useEffect - direct async/await
export default async function Page() {
  const data = await getProducts(); // runs on the server
  return <ProductTable products={data} />;
}
```

{% endif %}

