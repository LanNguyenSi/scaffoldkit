## Optimistic Updates

For quick edit interactions (inline field save, toggle, status change), use optimistic updates to give instant feedback.

```tsx
// Using TanStack Query mutation with optimistic update
const updateUser = useMutation({
  mutationFn: (data: UpdateUserInput) => updateUserApi(user.id, data),
  onMutate: async (newData) => {
    await queryClient.cancelQueries({ queryKey: userKeys.detail(user.id) });
    const previous = queryClient.getQueryData(userKeys.detail(user.id));
    queryClient.setQueryData(userKeys.detail(user.id), (old: User) => ({
      ...old,
      ...newData,
    }));
    return { previous };
  },
  onError: (_err, _vars, ctx) => {
    // Roll back on error
    queryClient.setQueryData(userKeys.detail(user.id), ctx?.previous);
    toast.error("Failed to save changes");
  },
  onSettled: () => {
    queryClient.invalidateQueries({ queryKey: userKeys.detail(user.id) });
  },
});
```

