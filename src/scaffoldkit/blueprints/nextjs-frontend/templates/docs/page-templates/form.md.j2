## Error Handling

### Field-Level Errors

React Hook Form + Zod surfaces errors per field. Display them below the field, not in a summary.

```tsx
<FormField
  label="Email"
  error={form.formState.errors.email?.message}
>
  <Input {...form.register("email")} type="email" />
</FormField>
```

### API / Server Errors

When the server returns an error (validation failed, conflict, etc.), display it as a form-level banner above the submit button.

```tsx
const [serverError, setServerError] = useState<string | null>(null);

const handleSubmit = async (values: FormValues) => {
  setServerError(null);
  try {
    await onSubmit(values);
  } catch (err) {
    if (err instanceof ApiError && err.status === 422) {
      // Map server validation errors to field errors
      err.fieldErrors?.forEach(({ field, message }) => {
        form.setError(field as keyof FormValues, { message });
      });
    } else {
      setServerError(err instanceof Error ? err.message : "An unexpected error occurred.");
    }
  }
};

// In JSX:
{serverError && (
  <div role="alert" className="rounded-md bg-destructive/10 p-4 text-sm text-destructive">
    {serverError}
  </div>
)}
```

