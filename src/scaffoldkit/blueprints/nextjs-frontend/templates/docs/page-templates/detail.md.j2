## Data Fetching

{% if router == "app-router" %}
```tsx
// src/app/(dashboard)/users/[id]/page.tsx
import { notFound } from "next/navigation";
import { getUserById } from "@/services/users";
import { UserDetailHeader } from "@/components/features/users/UserDetailHeader";
import { UserDetailTabs } from "@/components/features/users/UserDetailTabs";
import { Breadcrumbs } from "@/components/ui/Breadcrumbs";

interface PageProps {
  params: { id: string };
  searchParams: { tab?: string };
}

export default async function UserDetailPage({ params, searchParams }: PageProps) {
  const user = await getUserById(params.id);
  if (!user) notFound();

  return (
    <div className="space-y-6 p-6">
      <Breadcrumbs
        crumbs={[
          { label: "Home", href: "/" },
          { label: "Users", href: "/users" },
          { label: user.displayName },
        ]}
      />
      <UserDetailHeader user={user} />
      <UserDetailTabs user={user} activeTab={searchParams.tab ?? "overview"} />
    </div>
  );
}

export async function generateMetadata({ params }: PageProps) {
  const user = await getUserById(params.id);
  return {
    title: user ? `${user.displayName} | {{ display_name }}` : "Not Found",
  };
}
```
{% else %}
```tsx
// src/pages/users/[id].tsx
import type { GetServerSideProps } from "next";

export const getServerSideProps: GetServerSideProps = async ({ params }) => {
  const user = await getUserById(params?.id as string);
  if (!user) return { notFound: true };
  return { props: { user } };
};
```
{% endif %}

