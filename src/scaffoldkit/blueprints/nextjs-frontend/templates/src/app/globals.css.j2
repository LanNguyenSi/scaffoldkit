{% if styling == "tailwind" -%}
@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  --background: #ffffff;
  --foreground: #0a0a0a;
  --card: #ffffff;
  --muted-foreground: #6b7280;
}

body {
  background: var(--background);
  color: var(--foreground);
}
{%- else -%}
:root {
  --background: #ffffff;
  --foreground: #0a0a0a;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  background: var(--background);
  color: var(--foreground);
  font-family: system-ui, -apple-system, sans-serif;
}
{%- endif %}
