## Installation

### 1. Clone and install dependencies

```bash
git clone <repo-url> {{ project_name }}
cd {{ project_name }}
composer install
```

### 2. Configure environment

```bash
cp .env .env.local
# Edit .env.local with your local values
```

Key variables to set in `.env.local`:

```dotenv
APP_ENV=dev
APP_SECRET=change-me-to-a-random-32-char-string

{% if database == "postgresql" %}
DATABASE_URL="postgresql://app:password@127.0.0.1:5432/{{ project_name }}?serverVersion=15&charset=utf8"
{% elif database == "mysql" %}
DATABASE_URL="mysql://app:password@127.0.0.1:3306/{{ project_name }}?serverVersion=8.0&charset=utf8mb4"
{% elif database == "mariadb" %}
DATABASE_URL="mysql://app:password@127.0.0.1:3306/{{ project_name }}?serverVersion=10.11-MariaDB&charset=utf8mb4"
{% endif %}
{% if use_auth and auth_method == "jwt" %}
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change-me
{% endif %}
{% if use_rabbitmq %}
MESSENGER_TRANSPORT_DSN=amqp://guest:guest@127.0.0.1:5672/%2f/messages
{% endif %}
{% if use_redis %}
REDIS_URL=redis://127.0.0.1:6379
{% endif %}
```

### 3. Set up the database

```bash
# Create the database
php bin/console doctrine:database:create

# Run migrations
php bin/console doctrine:migrations:migrate --no-interaction
```

{% if use_auth and auth_method == "jwt" %}
### 4. Generate JWT keys

```bash
php bin/console lexik:jwt:generate-keypair
```
{% endif %}

### 5. Start the development server

```bash
symfony server:start
# or
php -S 127.0.0.1:8000 -t public/
```

