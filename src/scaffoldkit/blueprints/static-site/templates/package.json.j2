{
  "name": "{{ project_name }}",
  "version": "0.1.0",
  "private": true,
  "description": "{{ description }}",
  "scripts": {
{% if framework == "astro" %}
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test": "node --test"
{% elif framework == "nextjs-static" %}
    "dev": "next dev",
    "build": "next build",
    "preview": "next start"
{% elif framework == "eleventy" %}
    "dev": "npx @11ty/eleventy --serve",
    "build": "npx @11ty/eleventy"
{% else %}
    "dev": "hugo server --buildDrafts",
    "build": "hugo",
    "preview": "hugo server"
{% endif %}
  },
  "engines": {
    "node": ">=20"
  }{% if framework != "hugo" %},
  "dependencies": {
{% if framework == "astro" %}
{% if styling == "tailwind" %}
    "astro": "^5.5.2",
    "@astrojs/tailwind": "^5.1.5",
    "tailwindcss": "^3.4.17"
{% else %}
    "astro": "^5.5.2"
{% endif %}
{% elif framework == "nextjs-static" %}
    "next": "^15.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
{% else %}
    "@11ty/eleventy": "^3.0.0"
{% endif %}
  }{% if framework == "astro" %},
  "devDependencies": {
    "@types/node": "^22.13.14"
  }
{% endif %}
{% endif %}
}
