name: Site Pipeline

on:
  push:
    branches:
      - main
  pull_request:

permissions:
  contents: read
  pages: write
  id-token: write

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v4
{% if framework == "hugo" %}
      - name: Set up Hugo
        uses: peaceiris/actions-hugo@v3
        with:
          hugo-version: "0.125.0"
          extended: true

      - name: Build site
        shell: bash
        run: |
          if [ -f hugo.toml ] || [ -f config.toml ] || [ -f config.yaml ] || [ -f config.yml ]; then
            hugo
          else
            echo "Hugo config is not generated by this scaffold. Skipping site build."
          fi
{% else %}
      - name: Set up Node.js
        uses: actions/setup-node@v4
        with:
          node-version: "22"

      - name: Build site
        shell: bash
        run: |
          if [ ! -f package.json ]; then
            echo "package.json is not generated by this scaffold. Skipping site build."
            exit 0
          fi
          corepack enable || true
          if [ -f pnpm-lock.yaml ]; then
            pnpm install --frozen-lockfile || pnpm install
            pnpm build
          elif [ -f yarn.lock ]; then
            yarn install --frozen-lockfile || yarn install
            yarn build
          elif [ -f package-lock.json ]; then
            npm ci
            npm run build
          else
            npm install
            npm run build
          fi
{% endif %}
