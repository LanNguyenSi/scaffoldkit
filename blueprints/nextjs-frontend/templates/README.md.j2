│   ├── hooks/                # Custom React hooks
│   ├── lib/                  # Third-party client config (e.g., queryClient)
│   ├── services/             # API service layer (typed fetch wrappers)
│   ├── styles/               # Global CSS, design tokens
│   └── types/                # Shared TypeScript types
{% else %}
├── src/
│   ├── pages/                # Pages Router: each file is a route
│   │   ├── api/              # API routes
│   │   ├── _app.tsx          # App wrapper (providers)
│   │   ├── _document.tsx     # HTML document shell
│   │   └── index.tsx         # Home page
│   ├── components/
│   │   ├── ui/               # Headless/primitive UI components
│   │   ├── layout/           # Structural components (Header, Sidebar)
│   │   └── features/         # Domain-specific feature components
│   ├── hooks/                # Custom React hooks
│   ├── lib/                  # Third-party client config
│   ├── services/             # API service layer
│   ├── styles/               # Global CSS, design tokens
│   └── types/                # Shared TypeScript types
{% endif %}
├── public/                   # Static assets (images, fonts, favicons)
├── docs/
│   ├── architecture.md       # System architecture and data flow
│   ├── ways-of-working.md    # Team conventions and DoD
│   ├── component-guide.md    # Component patterns and conventions
│   ├── adrs/                 # Architecture Decision Records
│   └── page-templates/       # Structural reference for standard pages
{% if ai_context %}
├── AI_CONTEXT.md             # AI agent context - read before coding
{% endif %}
├── .env.example              # Example environment variables
└── README.md
```

