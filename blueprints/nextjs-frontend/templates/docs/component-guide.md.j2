## How to Create a New Component

Follow these steps every time you add a new component.

### Step 1: Decide the category

- No domain knowledge, purely visual? -> `src/components/ui/`
- Part of the application shell? -> `src/components/layout/`
- Tied to a business concept? -> `src/components/features/<domain>/`

### Step 2: Create the file(s)

For a simple component:

```
src/components/features/users/
├── UserCard.tsx
├── UserCard.skeleton.tsx
├── UserCard.test.tsx
{% if use_storybook %}
├── UserCard.stories.tsx
{% endif %}
```

For a complex component with its own sub-components, use a directory:

```
src/components/features/users/UserCard/
├── index.tsx               # re-exports the public API
├── UserCard.tsx            # main component
├── UserCardAvatar.tsx      # sub-component
├── UserCard.skeleton.tsx
├── UserCard.test.tsx
{% if use_storybook %}
└── UserCard.stories.tsx
{% endif %}
```

### Step 3: Write the component

```tsx
// src/components/features/users/UserCard.tsx
import type { User } from "@/types/user";
import { Avatar } from "@/components/ui";
import { cn } from "@/lib/utils";

interface UserCardProps {
  user: User;
  onSelect?: (id: string) => void;
  isSelected?: boolean;
  className?: string;
}

export function UserCard({
  user,
  onSelect,
  isSelected = false,
  className,
}: UserCardProps) {
  return (
    <div
      role="button"
      tabIndex={0}
      aria-pressed={isSelected}
      onClick={() => onSelect?.(user.id)}
      onKeyDown={(e) => {
        if (e.key === "Enter" || e.key === " ") onSelect?.(user.id);
      }}
      className={cn(
        "flex cursor-pointer items-center gap-3 rounded-lg border p-4 transition-colors",
        isSelected ? "border-primary bg-primary/5" : "hover:bg-muted",
        className
      )}
    >
      <Avatar src={user.avatarUrl} alt={user.displayName} />
      <div>
        <p className="font-medium">{user.displayName}</p>
        <p className="text-sm text-muted-foreground">{user.email}</p>
      </div>
    </div>
  );
}
```

### Step 4: Write the test

```tsx
// src/components/features/users/UserCard.test.tsx
import { render, screen } from "@testing-library/react";
import userEvent from "@testing-library/user-event";
import { UserCard } from "./UserCard";
import { mockUser } from "@/test/factories/user";

describe("UserCard", () => {
  it("renders the user display name and email", () => {
    render(<UserCard user={mockUser} />);
    expect(screen.getByText(mockUser.displayName)).toBeInTheDocument();
    expect(screen.getByText(mockUser.email)).toBeInTheDocument();
  });

  it("calls onSelect with the user id when clicked", async () => {
    const onSelect = vi.fn();
    render(<UserCard user={mockUser} onSelect={onSelect} />);
    await userEvent.click(screen.getByRole("button"));
    expect(onSelect).toHaveBeenCalledWith(mockUser.id);
  });

  it("marks the card as pressed when isSelected is true", () => {
    render(<UserCard user={mockUser} isSelected />);
    expect(screen.getByRole("button")).toHaveAttribute("aria-pressed", "true");
  });
});
```

### Step 5: Export from barrel

```ts
// src/components/features/users/index.ts
export { UserCard } from "./UserCard";
export { UserCardSkeleton } from "./UserCard.skeleton";
```

{% if use_storybook %}
### Step 6: Write the story

```tsx
// src/components/features/users/UserCard.stories.tsx
import type { Meta, StoryObj } from "@storybook/react";
import { UserCard } from "./UserCard";
import { mockUser } from "@/test/factories/user";

const meta: Meta<typeof UserCard> = {
  title: "Features/Users/UserCard",
  component: UserCard,
  args: { user: mockUser },
};
export default meta;

type Story = StoryObj<typeof UserCard>;

export const Default: Story = {};
export const Selected: Story = { args: { isSelected: true } };
export const WithoutAvatar: Story = {
  args: { user: { ...mockUser, avatarUrl: null } },
};
```

{% endif %}

