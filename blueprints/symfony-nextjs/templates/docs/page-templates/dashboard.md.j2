## Client Component: DataTable

The `DataTable` receives its initial data from the Server Component. Subsequent page changes and searches update the URL via `router.push`, causing the Server Component to re-render with new data from the API.

```typescript
// apps/web/src/components/features/dashboard/DataTable.tsx
'use client';

import { useRouter, useSearchParams } from 'next/navigation';
import { useCallback, useTransition } from 'react';
import type { User, PaginationMeta } from '@{{ project_name }}/shared-types';

interface DataTableProps {
  initialData: User[];
  meta: PaginationMeta;
  currentPage: number;
  currentSearch: string;
}

export function DataTable({ initialData, meta, currentPage, currentSearch }: DataTableProps) {
  const router = useRouter();
  const [isPending, startTransition] = useTransition();

  const navigate = useCallback((params: Record<string, string | number>) => {
    const sp = new URLSearchParams(window.location.search);
    Object.entries(params).forEach(([k, v]) => sp.set(k, String(v)));
    startTransition(() => router.push(`?${sp}`));
  }, [router]);

  return (
    <div className={isPending ? 'opacity-60 pointer-events-none' : ''}>
      {/* Search input, table rows, pagination controls */}
    </div>
  );
}
```

**Key pattern:** The URL is the state. `searchParams` flow through the Server Component which re-fetches from the API. The Client Component only handles user interactions that update the URL.

